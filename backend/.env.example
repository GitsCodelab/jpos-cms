# JPOS CMS Configuration

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jpos_cms
# For Oracle: oracle://MAIN:main123@localhost:1521/?service_name=xepdb1

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# API Configuration
API_TITLE=jPOS CMS API
API_VERSION=1.0.0

# Environment
ENVIRONMENT=development
DEBUG=true

# Logging
LOG_LEVEL=INFO

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_TOKEN_REFRESH=true
